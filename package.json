{
  "name": "cosmic-dust-canvas",
  "version": "0.1.1",
  "description": "A reusable React component that renders hundreds of softly glowing particles drifting across the screen and reacting to the user's mouse.",
  "keywords": [
    "react",
    "particles",
    "canvas",
    "animation",
    "cosmic",
    "background"
  ],
  "author": "Muhammad Umair Ali",
  "license": "MIT",
  "type": "module",
  "main": "dist/cosmic-dust-canvas.cjs",
  "module": "dist/cosmic-dust-canvas.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cosmic-dust-canvas.js",
      "require": "./dist/cosmic-dust-canvas.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "demo": "vite demo",
    "demo:build": "tsc --noEmit -p demo/tsconfig.json && vite build demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0"
  }
}
